{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug run_tests",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/cmake-build-debug/Debug/bin/run_tests",
            "args": [
                "--gtest_filter=ThreadSafeRingBufferTest.ConcurrentClear"
            ],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "build run_tests",
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "stopAtEntry": false,
            "environment": [],
            "externalConsole": false,
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}
