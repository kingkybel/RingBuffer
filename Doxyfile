# Note that enabling this option will significantly increase the time of a run.
# So in most cases it will be better to enable caller graphs for selected
# functions only using the \callergraph command. Disabling a caller graph can be
# accomplished by means of the command \hidecallergraph.
# The default value is: NO.
# This tag requires that the tag HAVE_DOT is set to YES.

CALLER_GRAPH           = NO

# If the GRAPHICAL_HIERARCHY tag is set to YES then doxygen will graphical
# hierarchy of all classes instead of a textual one.
# The default value is: YES.
# This tag requires that the tag HAVE_DOT is set to YES.

GRAPHICAL_HIERARCHY    = YES

# If the DIRECTORY_GRAPH tag is set to YES then doxygen will show a graph of the
# dependencies between directories in html output. The dependency relations are
# determined by the #include relations between the files found in the directories.
# Directory dependencies will also be computed for HTML output. This can take a
# while to compute if a large amount of files is found in the documented project.
# The default value is: YES.
# This tag requires that the tag HAVE_DOT is set to YES.

DIRECTORY_GRAPH        = YES

# The DOT_IMAGE_FORMAT tag can be used to set the image format of the images
# generated by dot. For an HTML output, a gif format is usually best. If
# HAVE_DOT is set to YES and DOT_IMAGE_FORMAT is gif, then the HTML output will
# contain PNG images (produced by the convert tool) instead of the normal gif
# ones, because of limitations of Internet Explorer. For Unix users working on
# an X11 display, png is a better choice because it is viewable in a Mozilla
# browser without an external plug-in. But note that display of PNG images is
# currently not supported if the output is HTML HHC. For all other users gif
# is a good choice.
#
# Note: If you choose svg you need to install Internet Explorer SVG plugin
# (see: https://web.archive.org/web/20090206133608/http://www.adobe.com/svg/viewer/install/),
# or set HTML_FILE_EXTENSION to xhtml in order to make the SVG files
# viewable in any browser. HTML_HHC may be used as alternative if you do not
# want to require XHTML.
# Possible values are: png, png:cairo, png:cairo:cairo, png:cairo:gd, png:gd,
# png:gd:gd, jpg, jpg:cairo, jpg:cairo:cairo, jpg:cairo:gd, jpg:gd, jpg:gd:gd,
# gif, gif:cairo, gif:cairo:cairo, gif:cairo:gd, gif:gd, gif:gd:gd, svg, png-mono,
# png-mono:cairo, png-mono:cairo:cairo, png-mono:cairo:gd, png-mono:gd,
# png-mono:gd:gd, png-transparent, png-transparent:cairo,
# png-transparent:cairo:cairo, png-transparent:cairo:gd, png-transparent:gd,
# png-transparent:gd:gd, png-interlaced, png-interlaced:cairo,
# png-interlaced:cairo:cairo, png-interlaced:cairo:gd, png-interlaced:gd,
# png-interlaced:gd:gd, bmp, bmp:cairo, bmp:cairo:cairo, bmp:cairo:gd, bmp:gd,
# bmp:gd:gd, ico, ico:cairo, ico:cairo:cairo, ico:cairo:gd, ico:gd, ico:gd:gd.
# The default value is: png.
# This tag requires that the tag HAVE_DOT is set to YES.

DOT_IMAGE_FORMAT       = png

# If DOT_IMAGE_FORMAT is set to svg, then this option can be set to YES to
# enable generation of interactive SVG images that allow zooming and panning.
#
# Note that this requires a modern browser other than Internet Explorer. Tested
# and working are Firefox, Chrome, Safari, and Opera.
# The default value is: NO.
# This tag requires that the tag HAVE_DOT is set to YES.

INTERACTIVE_SVG        = NO

# The DOT_PATH tag can be used to specify the path where the dot tool can be
# found. If left blank, it is assumed the dot tool can be found in the path.
# This tag requires that the tag HAVE_DOT is set to YES.

DOT_PATH               =

# The DOTFILE_DIRS tag can be used to specify one or more directories that
# contain dot files that are included in the documentation (see the \dotfile
# command).
# This tag requires that the tag HAVE_DOT is set to YES.

DOTFILE_DIRS           =

# The MSCFILE_DIRS tag can be used to specify one or more directories that
# contain msc files that are included in the documentation (see the \mscfile
# command).

MSCFILE_DIRS           =

# The DIAFILE_DIRS tag can be used to specify one or more directories that
# contain dia files that are included in the documentation (see the \diafile
# command).

DIAFILE_DIRS           =

# When using plantuml, the PLANTUML_JAR_PATH tag should be used to specify the
# path where java can find the plantuml.jar file. If left blank, it is assumed
# the plantuml.jar file is in the CLASSPATH or in the current working directory.

PLANTUML_JAR_PATH      =

# When using plantuml, the specified paths are only searched for plantuml.jar
# and for include files specified in plantuml source files. In this case the
# plantuml -I option is used to specify the directories.

PLANTUML_INCLUDE_PATH  =

# When using plantuml, the PLANTUML_CFG_FILE tag can be used to specify a
# configuration file for plantuml, i.e. a file that sets a number of plantuml
# configuration options using the plantuml !define command.

PLANTUML_CFG_FILE      =

# When using plantuml, the specified paths are only searched for config files
# specified in plantuml source files. In this case the plantuml -I option is
# used to specify the directories.

PLANTUML_INCLUDE_CONFIG_PATH =

# When using plantuml, the PLANTUML_CLI_ARGS tag can be used to specify any
# additional arguments that are passed to the plantuml command. For example,
# to use the -enableexperimental switch, you would add "-enableexperimental"
# to this list.

PLANTUML_CLI_ARGS      =

# When using plantuml, the PLANTUML_SOURCE_INSIDE tag specifies where the plantuml
# source in an image will be placed. It can be set to "at_start", "at_end", or
# "never". If set to "at_start", the plantuml source will be placed before the
# image. If set to "at_end", the plantuml source will be placed after the image.
# If set to "never", the plantuml source will not be placed in the image.

PLANTUML_SOURCE_INSIDE = at_start

# When using plantuml, the PLANTUML_SOURCE_INCLUDE_TAGS tag can be used to specify
# a list of tags that will be used to include plantuml source in the documentation.
# For example, if set to "startuml", then plantuml source will be included in the
# documentation when the tag @startuml is encountered.

PLANTUML_SOURCE_INCLUDE_TAGS =

# When using plantuml, the PLANTUML_SOURCE_EXCLUDE_TAGS tag can be used to specify
# a list of tags that will be used to exclude plantuml source from the documentation.
# For example, if set to "enduml", then plantuml source will be excluded from the
# documentation when the tag @enduml is encountered.

PLANTUML_SOURCE_EXCLUDE_TAGS =

# When using plantuml, the DOT_MULTI_TARGETS tag can be used to generate
# multiple targets for dot files. This is useful when you want to generate
# multiple images from a single dot file.

DOT_MULTI_TARGETS      = NO

# When using plantuml, the DOT_TRANSPARENT tag can be used to generate
# transparent images. This is useful when you want to overlay images.

DOT_TRANSPARENT        = NO

# When using plantuml, the DOT_IMAGE_STEM tag can be used to specify the
# stem for the image file name. This is useful when you want to generate
# multiple images with the same stem.

DOT_IMAGE_STEM         =

# When using plantuml, the DOT_CLEANUP tag can be used to specify whether
# or not to cleanup the intermediate files generated by dot. This is useful
# when you want to keep the intermediate files for debugging purposes.

DOT_CLEANUP            = YES